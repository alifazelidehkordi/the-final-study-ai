{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/alifazelidehkordi/the-final-study-ai/schemas/run-manifest-v1.schema.json",
  "title": "Final Study Run Manifest v1",
  "type": "object",
  "required": [
    "schema", "version", "run_id", "created_at", "updated_at", "status",
    "preset", "source", "paths", "options", "tool_versions", "stages",
    "items", "artifacts", "last_error"
  ],
  "properties": {
    "schema": {"const": "final-study.run"},
    "version": {"const": 1},
    "run_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "status": {
      "enum": [
        "created", "running", "awaiting_review", "stop_requested", "stopped",
        "interrupted", "partial", "failed", "completed"
      ]
    },
    "preset": {"enum": ["complete", "markdown_index", "mindmaps_only"]},
    "source": {"type": "object"},
    "paths": {"type": "object"},
    "options": {"type": "object"},
    "tool_versions": {"type": "object"},
    "stages": {"type": "object"},
    "items": {"type": "object"},
    "artifacts": {"type": "array"},
    "last_error": {"type": ["object", "null"]}
  },
  "additionalProperties": false
}
